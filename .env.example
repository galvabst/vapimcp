# Required for Vapi API access. Get from https://dashboard.vapi.ai/org/api-keys
VAPI_TOKEN=your-vapi-api-key

# Optional: MCP_MODE = stdio (Cursor/Claude) or http (Railway/Lovable). Default: stdio locally, http in production.
# MCP_MODE=http

# Optional: Bearer token for HTTP/SSE (Lovable). If set, /sse and /messages require Authorization: Bearer <key>
# MCP_API_KEY=optional-secret-for-lovable

# Optional: PORT for HTTP mode (Railway injects PORT)
# PORT=3000

# Optional: LOG_LEVEL = debug | info | warn | error
# LOG_LEVEL=info
